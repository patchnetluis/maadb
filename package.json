{
  "name": "@maadb/core",
  "version": "0.7.8",
  "description": "Markdown As A Database — treats markdown as the canonical data store, builds a queryable index, and gives LLMs deterministic read/write access.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maadb/maadb.git"
  },
  "homepage": "https://github.com/maadb/maadb#readme",
  "bugs": {
    "url": "https://github.com/maadb/maadb/issues"
  },
  "type": "module",
  "main": "dist/engine.js",
  "types": "dist/engine.d.ts",
  "bin": {
    "maad": "dist/cli.js"
  },
  "files": [
    "dist/",
    "MAAD.md",
    "_skills/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "serve": "node dist/cli.js serve"
  },
  "keywords": [
    "markdown",
    "database",
    "llm",
    "mcp",
    "yaml",
    "indexing"
  ],
  "author": "Luis Martinez <luis@patchnet.ai>",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.9.0",
    "gray-matter": "~4.0.3",
    "js-yaml": "~4.1.1",
    "pino": "10.3.1",
    "simple-git": "3.35.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "~7.6.13",
    "@types/js-yaml": "~4.0.9",
    "@types/node": "~24.11.0",
    "pino-pretty": "~13.1.3",
    "typescript": "~6.0.2",
    "vitest": "~4.1.3"
  }
}
